// Lumora-Logo + VersionInfo der nativen Shell.
#include <windows.h>

IDI_ICON1 ICON "app.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 3,0,0,0
 PRODUCTVERSION 3,0,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Karsten Radermacher"
            VALUE "FileDescription", "Lumora"
            VALUE "FileVersion", "3.0.0.0"
            VALUE "InternalName", "lumora-shell"
            VALUE "LegalCopyright", "\xA9 Karsten Radermacher"
            VALUE "OriginalFilename", "lumora-shell.exe"
            VALUE "ProductName", "Lumora"
            VALUE "ProductVersion", "3.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

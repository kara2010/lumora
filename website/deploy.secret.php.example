<?php
// VORLAGE. Kopie ohne ".example" (also: deploy.secret.php) NUR auf den Server legen,
// niemals ins Repo (ist in .gitignore).
//
// Token erzeugen z.B. mit:  php -r "echo bin2hex(random_bytes(48));"
//
// EMPFOHLEN (Array-Form): Token + Pfad-Policy. 'deny' haelt den unsignierten
// Auto-Update-Feed ausserhalb der Reichweite dieses Tokens -> ein Token-Leak
// kann dann KEINE Malware ueber den Updater verteilen (Supply-Chain-Schutz).
return [
  'token' => 'HIER-DAS-GEHEIME-TOKEN-EINSETZEN',
  'deny'  => ['updates/'],   // updates/ bleibt manueller Upload, bis Releases signiert sind
  // 'allow' => ['index.html','en/','download.php','gruppe.php'],  // optional: NUR diese Praefixe erlauben
];

// Minimal-Form (gesamter eigener Baum erlaubt) waere alternativ:
//   return 'HIER-DAS-GEHEIME-TOKEN-EINSETZEN';

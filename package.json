{
  "name": "lumora",
  "version": "2.0.0",
  "description": "Lumora – Game Launcher mit automatischem HDR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.lumora.app",
    "productName": "Lumora",
    "files": [
      "main.js",
      "index.html",
      "styles.css",
      "icon.ico",
      "icon-64.png",
      "package.json"
    ],
    "compression": "maximum",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "extraResources": [
      {
        "from": "HDRCmd.exe",
        "to": "HDRCmd.exe"
      },
      {
        "from": "HDRTray-LICENSE.html",
        "to": "HDRTray-LICENSE.html"
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^25.0.0"
  }
}

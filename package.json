{
  "name": "lumora",
  "version": "2.2.0",
  "description": "Lumora – Game Launcher mit automatischem HDR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.lumora.app",
    "productName": "Lumora",
    "files": [
      "**/*",
      "!_testlab${/*}",
      "!website${/*}",
      "!dist${/*}",
      "!.claude${/*}",
      "!**/*.zip",
      "!screenshot1.png",
      "!screenshot2.png",
      "!icon-source.png",
      "!color.png",
      "!tray-icon.png",
      "!afterpack.js",
      "!installer.nsh"
    ],
    "compression": "maximum",
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/koffi/**",
      "**/node_modules/@koromix/**"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://kara-webdesign.de/hdr-launcher/updates/"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "include": "installer.nsh"
    },
    "extraResources": [
      {
        "from": "HDRCmd.exe",
        "to": "HDRCmd.exe"
      },
      {
        "from": "HDRTray-LICENSE.html",
        "to": "HDRTray-LICENSE.html"
      },
      {
        "from": "PresentMon.exe",
        "to": "PresentMon.exe"
      },
      {
        "from": "PresentMon-LICENSE.txt",
        "to": "PresentMon-LICENSE.txt"
      },
      {
        "from": "AMDFamily17.bin",
        "to": "AMDFamily17.bin"
      },
      {
        "from": "IntelMSR.bin",
        "to": "IntelMSR.bin"
      },
      {
        "from": "PawnIO-Modules-LICENSE.txt",
        "to": "PawnIO-Modules-LICENSE.txt"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "koffi": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^25.0.0"
  }
}

{
  "name": "lumora",
  "version": "2.0.0",
  "description": "Lumora – Game Launcher mit automatischem HDR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.lumora.app",
    "productName": "Lumora",
    "files": [
      "**/*",
      "!_testlab${/*}",
      "!website${/*}",
      "!dist${/*}",
      "!.claude${/*}",
      "!**/*.zip",
      "!screenshot1.png",
      "!screenshot2.png",
      "!icon-source.png",
      "!color.png",
      "!tray-icon.png",
      "!afterpack.js"
    ],
    "compression": "maximum",
    "publish": [
      {
        "provider": "generic",
        "url": "https://kara-webdesign.de/hdr-launcher/updates/"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "extraResources": [
      {
        "from": "HDRCmd.exe",
        "to": "HDRCmd.exe"
      },
      {
        "from": "HDRTray-LICENSE.html",
        "to": "HDRTray-LICENSE.html"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^25.0.0"
  }
}

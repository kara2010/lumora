{
  "name": "lumora",
  "version": "2.2.21",
  "license": "AGPL-3.0-only",
  "author": "Karsten Radermacher",
  "description": "Lumora – Game Launcher mit automatischem HDR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.lumora.app",
    "productName": "Lumora",
    "protocols": [{ "name": "Lumora", "schemes": ["lumora"] }],
    "files": [
      "**/*",
      "!_testlab${/*}",
      "!website${/*}",
      "!dist${/*}",
      "!bin${/*}",
      "!capture${/*}",
      "!.claude${/*}",
      "!**/*.zip",
      "!screenshot1.png",
      "!screenshot2.png",
      "!icon-source.png",
      "!color.png",
      "!tray-icon.png",
      "!afterpack.js",
      "!installer.nsh"
    ],
    "compression": "maximum",
    "electronLanguages": ["en-US", "de"],
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/koffi/**",
      "**/node_modules/@koromix/**"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://lumora-streaming.de/updates/"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signtoolOptions": {
        "sign": "./sign.js",
        "signingHashAlgorithms": ["sha256"]
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "selectPerMachineByDefault": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh",
      "multiLanguageInstaller": true,
      "displayLanguageSelector": true,
      "installerLanguages": ["de_DE", "en_US"]
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "website/gruppe.php",
        "to": "gruppe.php"
      },
      {
        "from": "HDRCmd.exe",
        "to": "HDRCmd.exe"
      },
      {
        "from": "HDRTray-LICENSE.html",
        "to": "HDRTray-LICENSE.html"
      },
      {
        "from": "PresentMon.exe",
        "to": "PresentMon.exe"
      },
      {
        "from": "PresentMon-LICENSE.txt",
        "to": "PresentMon-LICENSE.txt"
      },
      {
        "from": "AMDFamily17.bin",
        "to": "AMDFamily17.bin"
      },
      {
        "from": "IntelMSR.bin",
        "to": "IntelMSR.bin"
      },
      {
        "from": "PawnIO-Modules-LICENSE.txt",
        "to": "PawnIO-Modules-LICENSE.txt"
      },
      {
        "from": "ffmpeg-LICENSE.txt",
        "to": "ffmpeg-LICENSE.txt"
      },
      {
        "from": "mediamtx-LICENSE.txt",
        "to": "mediamtx-LICENSE.txt"
      },
      {
        "from": "opus-LICENSE.txt",
        "to": "opus-LICENSE.txt"
      },
      {
        "from": "libvpl-LICENSE.txt",
        "to": "libvpl-LICENSE.txt"
      },
      {
        "from": "AMF-LICENSE.txt",
        "to": "AMF-LICENSE.txt"
      },
      {
        "from": "nv-codec-headers-LICENSE.txt",
        "to": "nv-codec-headers-LICENSE.txt"
      },
      {
        "from": "Vortice-LICENSE.txt",
        "to": "Vortice-LICENSE.txt"
      },
      {
        "from": "NAudio-LICENSE.txt",
        "to": "NAudio-LICENSE.txt"
      },
      {
        "from": "LICENSE",
        "to": "Lumora-LICENSE.txt"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "koffi": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^25.0.0"
  }
}
